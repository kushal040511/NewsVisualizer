# Copy this file to .env and fill in your keys.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TRANSLATION_MODEL=gemini-2.0-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models

# Optional: DeepL for primary translation with OpenAI fallback.
DEEPL_API_KEY=your_deepl_api_key_here
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Optional: LibreTranslate fallback for translation/detection.
LIBRETRANSLATE_API_URL=https://libretranslate.com
